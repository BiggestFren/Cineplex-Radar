# Required: long random token used by the Android app and Cloudflare tunnel.
APP_AUTH_TOKEN=replace-with-a-long-random-value

# Backend storage and scheduling.
DATABASE_PATH=/state/radar.db
ENABLE_WATCHER=true
POLL_INTERVAL_SECONDS=300
POLL_JITTER_SECONDS=45
BURST_MODE=false
BURST_INTERVAL_SECONDS=45
BURST_UNTIL=

# Cineplex public web API. Capture the current public subscription key from the
# website's redacted Network request; it is never logged by Radar.
CINEPLEX_BASE_URL=https://apis.cineplex.com/prod/cpx/theatrical/api
CINEPLEX_TICKETING_BASE_URL=https://apis.cineplex.com/prod/ticketing/api
CINEPLEX_SUBSCRIPTION_KEY=replace-from-current-redacted-capture
CINEPLEX_USER_AGENT=Mozilla/5.0 (Linux; Android 14) AppleWebKit/537.36 Chrome/126.0 Mobile Safari/537.36 Radar/0.1
CINEPLEX_REFERER=https://www.cineplex.com/

# Account/checkout safety gates. Keep all false until the pending authenticated
# traffic samples are captured and v2b is tested with the owner present.
ENABLE_CINEPLEX_ACCOUNT=false
ENABLE_CHECKOUT=false
ALLOW_UNATTENDED_BUY=false

# Push transport. The compose service is reachable as http://ntfy inside Docker.
NTFY_BASE_URL=http://ntfy:80
PUBLIC_NTFY_BASE_URL=https://ntfy.example.com
NTFY_TOPIC=replace-with-a-private-unguessable-topic
NTFY_TOKEN=
# The starter compose setup permits an unguessable private topic. After creating
# an ntfy user/token, change this to deny-all and set NTFY_TOKEN above.
NTFY_AUTH_DEFAULT_ACCESS=read-write
DISCORD_WEBHOOK_URL=

# Official TMDB discovery API.
TMDB_API_KEY=
TMDB_REGION=CA

# nano-gpt OpenAI-compatible API.
LLM_BASE_URL=https://nano-gpt.com/api/v1
LLM_API_KEY=
LLM_MODEL=

# Toronto default; replace with approximate home coordinates if desired.
HOME_LATITUDE=43.6532
HOME_LONGITUDE=-79.3832
